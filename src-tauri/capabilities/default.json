{
  "identifier": "default",
  "description": "default permissions for 3LO",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:app:default",
    "core:path:default",
    "core:path:allow-join",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write",
    "fs:write-files",
    "fs:allow-read",
    "fs:allow-read-dir",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "fs:scope",
      "allow": [
        {"path": "$HOME/*"},
        {"path": "$HOME/**/*"},
        {"path": "$APPDATA/*"},
        {"path": "$APPDATA/**/*"}
      ]
    }
  ]
}
